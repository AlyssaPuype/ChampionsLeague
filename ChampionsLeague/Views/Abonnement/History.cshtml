@model IEnumerable<ChampionsLeague.Domains.Entities.Abonnement>

@{
    ViewData["Title"] = "Mijn abonnementen";
}

<h1>Mijn abonnementen</h1>

@if (!Model.Any())
{
    <p>Geen abonnementen gekocht.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Club</th>
                <th>Stadion</th>
                <th>Zitplaats</th>
                <th>Vak</th>
                <th>Prijs</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var abonnement in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(abonnement.Club?.LogoPath))
                        {
                            <img src="@abonnement.Club.LogoPath" height="25" class="me-2" />
                        }
                        @abonnement.Club?.Naam
                    </td>
                    <td>@abonnement.Club?.Stadion?.Naam</td>
                    <td>@abonnement.Zitplaats?.ZitplaatsNummer</td>
                    <td>@abonnement.Zitplaats?.Stadionvak?.Naam</td>
                    <td>€@abonnement.Prijs</td>
                </tr>
            }
        </tbody>
    </table>
}
