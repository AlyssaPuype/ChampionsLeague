@model ChampionsLeague.Models.Order.OrderAbonnementVM

@{
    ViewData["Title"] = "Abonnement kopen";
}

<h1>Abonnement kopen</h1>

<section class="ticket-details-container">
    <h4>Club details</h4>
    <p class="clubnames">@Model.Club.Naam</p>
    <p>Stadion: @Model.Club.Stadion?.Naam</p>
    <p>Capaciteit: @Model.Club.Stadion?.Capaciteit</p>
</section>

<section class="ticket-form-container">
    <p>Een abonnement geeft je dezelfde zitplaats voor alle thuismatches van @Model.Club.Naam.</p>
    <p><strong>Prijs: €200</strong></p>

    <form asp-controller="Order" asp-action="AddAbonnementToCart" method="post">
        <input type="hidden" asp-for="ClubId" />

        <div class="stadionvak">
            <label>Stadionvak</label>
            <select asp-for="GeselecteerdStadionvakId">
                <option value="">Selecteer een stadionvak</option>
                @foreach (var vak in Model.Stadionvakken)
                {
                    <option value="@vak.Id">@vak.Ring - @vak.Partij</option>
                }
            </select>
        </div>

        <!--toon beschikbare capaciteit van een stadionvak-->
        <div id="beschikbaar-info" style="display:none;" class="mt-2">
            <span id="beschikbaar-aantal"></span> plaatsen beschikbaar in dit vak
        </div>
        
        <button type="submit" class="btn btn-primary mt-3">Voeg toe aan winkelmand</button>
    </form>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mt-3">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@error.ErrorMessage</p>
            }
        </div>
    }
</section>


<!--AJAX gebruikt om dynamisch het aantal beschikbare plaatsen weer te geven nadat met het stadionvak heeft geselecteerd-->
@section Scripts {
    <script>
                document.getElementById('GeselecteerdStadionvakId').addEventListener('change', function () {
            const vakId = this.value;

            if (!vakId) {
                document.getElementById('beschikbaar-info').style.display = 'none';
                return;
            }

            fetch(`/Order/GetAantalBeschikbaar?stadionvakId=${vakId}`)
                .then(r => r.json())
                .then(aantal => {
                    document.getElementById('beschikbaar-aantal').textContent = aantal;
                    document.getElementById('beschikbaar-info').style.display = 'block';
                })
                .catch(err => {
                    console.error('Fout bij ophalen beschikbare plaatsen:', err);
                });
        });
    </script>
}