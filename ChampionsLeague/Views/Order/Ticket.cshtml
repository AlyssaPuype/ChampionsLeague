@model ChampionsLeague.Models.Order.OrderTicketVM

@{
    ViewData["Title"] = "Tickets kopen";

}

@section Styles {
    <link rel="stylesheet" href="~/css/OrderIndex.css" />
}

<h1>Koop tickets</h1>
<section class="ticket-details-container">
    <h4>Match details</h4>
    <p class="clubnames">@Model.Match.Thuisclub.Naam vs @Model.Match.Bezoekersclub.Naam</p>
    <p>Datum: @Model.Match.MatchDate</p>
    <p>Stadion: @Model.Match.Stadion.Naam</p>
</section>

<section class="ticket-form-container">
    <!--Bij gebruik van shoppingcart, asp-action veranderd van CreateTicket naar AddTicketToCart-->
    <form asp-action="AddTicketToCart" method="post">

        <!--Match is geselecteerd-->
        <input type="hidden" asp-for="GeselecteerdMatchId" />

        <!--selecteren van een stadionvak-->
        <div class="stadionvak">
            <label>Stadionvak</label>
            <select asp-for="GeselecteerdStadionvakId">
                <option value="">Selecteer een stadionvak</option>
                @foreach (var stadionvak in Model.Stadionvakken)
                {
                    <option value="@stadionvak.Id">@stadionvak.Ring - @stadionvak.Partij</option>
                }
            </select>
        </div>


        <!--toon beschikbare capaciteit van een stadionvak-->
        <div id="beschikbaar-info" style="display:none;" class="mt-2">
            <span id="beschikbaar-aantal"></span> plaatsen beschikbaar in dit vak
        </div>
        

        <!--selecteren van aantal tickets-->
        <div class="aantal-tickets">
            <label>Aantal tickets</label>
            <input asp-for="AantalTickets" type="number" value="1" />

        </div>
       
        <button type="submit">Voeg toe aan winkelmand</button>

    </form>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@error.ErrorMessage</p>
            }
        </div>
    }

</section>

<!--AJAX gebruikt om dynamisch het aantal beschikbare plaatsen weer te geven nadat met het stadionvak heeft geselecteerd-->
@section Scripts {
    <script>
        //Haal waarden op voor vak en match
        document.getElementById('GeselecteerdStadionvakId').addEventListener('change', function () {
            const vakId = this.value;
            const matchId = document.getElementById('GeselecteerdMatchId').value;

            //indien vak niet geselecteerd is, verberg info
            if (!vakId) {
                document.getElementById('beschikbaar-info').style.display = 'none';
                return;
            }

            //Anders: stuur data door naar ordercontroller
            //Zet response om in JSON
            //Zet de data in de view en maak info zichtb
            fetch(`/Order/GetAantalBeschikbaar?stadionvakId=${vakId}&matchId=${matchId}`)
                .then(r => r.json())
                .then(aantal => {
                    document.getElementById('beschikbaar-aantal').textContent = aantal;
                    document.getElementById('beschikbaar-info').style.display = 'block';
                });
                .catch(err => { console.error('Fout bij ophalen beschikbare plaatsen:', err);
        });
    </script>
}

