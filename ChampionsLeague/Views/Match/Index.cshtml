@model IEnumerable<Match>

@{
    ViewData["Title"] = "Matches Page";
    var groupedMatches = Model.GroupBy(m => m.MatchDate).OrderBy(g => g.Key);

}

@section Styles {
    <link rel="stylesheet" href="~/css/MatchIndex.css" />

}

<div class="matches-container">
    <h1>Matches</h1>

    <form method="get" asp-action="Index" class="mb-4">
        <select name="clubId" class="form-select w-auto d-inline-block" onchange="this.form.submit()">
            <option value="">Alle ploegen</option>
            @foreach (var item in (SelectList)ViewBag.Clubs)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>

            }
        </select>
    </form>

    <section class="match-container">
        <section>

            @foreach (var group in groupedMatches)
                {
                <h5>@($"{group.Key:dd MMMM yyyy}")</h5>
                    @foreach (var match in group)
                    {
                    <div class="card mb-3">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title mb-1">@match.Thuisclub.Naam vs @match.Bezoekersclub.Naam</h5>
                                <p class="card-text text-muted mb-0">@match.Stadion.Naam</p>
                            </div>
                            <div>
                                @if (match.MatchDate != null && match.MatchDate.Value <= DateOnly.FromDateTime(DateTime.Now.AddMonths(1)))
                                {
                                    <a asp-controller="Order" asp-action="Ticket" asp-route-matchid="@match.Id" class="btn btn-primary">Koop ticket</a>
                                }
                                else
                                {
                                    <button class="btn btn-dark" disabled>Nog niet beschikbaar</button>
                                }
                            </div>
                        </div>
                    </div>
                    }
                }
        </section>
    </section>
    
</div>

