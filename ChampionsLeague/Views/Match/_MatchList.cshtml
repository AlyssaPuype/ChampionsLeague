@model IEnumerable<Match>

@{
    var groupedMatches = Model.GroupBy(m => m.MatchDate).OrderBy(g => g.Key);
}

@foreach (var group in groupedMatches)
{
    <div class="date-container">
        <h5>@($"{group.Key:dd MMMM yyyy}")</h5>

        <div class="matches-per-date-container">
            @foreach (var match in group)
            {
                <div class="match-container">
                    <div class="match-body">
                        <div>
                            <h5>@match.Thuisclub.Naam vs @match.Bezoekersclub.Naam</h5>
                            <p>@match.Stadion.Naam</p>
                        </div>
                        <div>
                            @if (match.MatchDate != null && match.MatchDate.Value <= DateOnly.FromDateTime(DateTime.Now.AddMonths(1)))
                            {
                                <a asp-controller="Order" asp-action="Ticket" asp-route-matchid="@match.Id" class="btn btn-primary">Koop ticket</a>
                            }
                            else
                            {
                                <button class="btn btn-dark" disabled>Nog niet beschikbaar</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        
    </div>
   
}