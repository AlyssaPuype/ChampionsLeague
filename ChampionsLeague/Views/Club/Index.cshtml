@model IEnumerable<Club>

@{
    ViewData["Title"] = "Clubs Page";

}

@section Styles {
    <link rel="stylesheet" href="~/css/clubIndex.css" />
}

<div class="text-center">
    <h1 class="display-4">Clubs</h1>

    <section class="club-grid">
        @foreach (var club in Model)
        {
                <img src="@club.LogoPath" alt="@club.Naam" class="club-logo" />
        }
    </section>
    
</div>

