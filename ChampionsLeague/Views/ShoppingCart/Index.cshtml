@model ChampionsLeague.Models.ShoppingCartVM

@{
    ViewData["Title"] = "Winkelmandje";
}

<h3>Jouw winkelmandje</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model?.Carts?.Any() == true)
{
    <div class="row">
        <div class="col-6 navbar-text text-end">
            <small>
                <b>Winkelmandje:</b> @Model.Carts.Sum(x => x.AantalTickets) ticket(s) — €@Model.ComputeTotalValue()
            </small>
        </div>
    </div>

    <form asp-action="Payment" method="post">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Match</th>
                    <th>Datum</th>
                    <th>Stadion</th>
                    <th>Vak</th>
                    <th>Aantal</th>
                    <th>Prijs</th>
                    <th>Subtotaal</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (cartItem, index) in Model.Carts.Select((value, i) => (value, i)))
                {
                    <tr>
                        <td><input asp-for="@cartItem.MatchNaam" class="form-control" readonly /></td>
                        <td><input asp-for="@cartItem.MatchDatum" class="form-control" readonly /></td>
                        <td><input asp-for="@cartItem.StadionNaam" class="form-control" readonly /></td>
                        <td><input asp-for="@cartItem.StadionvakNaam" class="form-control" readonly /></td>
                        <td>
                            <input asp-for="@cartItem.AantalTickets" type="number"
                                   data-aantal="@index" min="1" max="4"
                                   class="form-control cart-item" data-index="@index" />
                        </td>
                        <td><input asp-for="@cartItem.Prijs" class="form-control" readonly /></td>
                        <td>
                            @{
                                var subtotal = cartItem.Prijs * cartItem.AantalTickets;
                            }
                            <input id="subtotal-@index" value="@subtotal" class="form-control" readonly />
                        </td>
                        <td>
                            <a asp-action="Delete" asp-route-matchId="@cartItem.MatchId"
                               class="btn btn-danger btn-sm">Verwijder</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row mt-3">
            <div class="col-md-6">
                <input type="submit" value="Afrekenen" class="btn btn-primary" />
            </div>
            <div class="col-md-6 text-end">
                <strong>Totaal: </strong>
                <input id="txtTotal" value="@Model.ComputeTotalValue()"
                       class="form-control d-inline w-auto" readonly />
            </div>
        </div>
    </form>
}
else
{
    <p>Je winkelmandje is leeg.</p>
}

<a asp-controller="Match" asp-action="Index" class="btn btn-secondary mt-3">
    Verder winkelen
</a>

@section Scripts {
    <script>
        $(document).ready(() => {
            $("[id$=AantalTickets]").on("change", (e) => {
                let row = $(e.currentTarget).closest("tr");
                let quantity = $(e.currentTarget).val();
                let price = row.find("input[id$='_Prijs']").val();
                let subtotal = quantity * price;
                let number = $(e.currentTarget).data("aantal");

                $("#subtotal-" + number).val(subtotal);

                let total = 0;
                $("input[id^=subtotal-]").each((index, el) => {
                    let val = parseFloat($(el).val());
                    if (!isNaN(val)) total += val;
                });

                $("#txtTotal").val(total);
            });
        });
    </script>
}