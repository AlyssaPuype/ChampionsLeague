@model ChampionsLeague.Models.ShoppingCartVM

@{
    ViewData["Title"] = "Winkelmandje";
}

<h3>Jouw winkelmandje</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!--Gekozen Ticketjes tonen-->
@if (Model?.Carts?.Any() == true)
{

    <h5>Tickets</h5>
    <table class="table table-striped">
            <thead>
                <tr>
                    <th>Match</th>
                    <th>Datum</th>
                    <th>Stadion</th>
                    <th>Vak</th>
                    <th>Aantal</th>
                    <th>Prijs</th>
                    <th>Subtotaal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (cartItem, index) in Model.Carts.Select((value, i) => (value, i)))
                {
                    <tr>
                        <td>@cartItem.MatchNaam</td>
                        <td>@cartItem.MatchDatum</td>
                        <td>@cartItem.StadionNaam</td>
                        <td>@cartItem.StadionvakNaam</td>
                        <td>@cartItem.AantalTickets</td>
                        <td>€@cartItem.Prijs</td>
                        <td>€@(cartItem.Prijs* cartItem.AantalTickets)</td>
                        <td>
                            <a asp-action="Delete"
                               asp-route-matchId="@cartItem.MatchId"
                               asp-route-stadionvakId="@cartItem.StadionvakId"
                               class="btn btn-danger btn-sm">Verwijder</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
 }

 <!--Gekozen Abonnenmenten tonen-->

  @if (Model?.AbonnementCarts?.Any() == true)
  {
            <h5>Abonnementen</h5>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Club</th>
                        <th>Prijs</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var abonnement in Model.AbonnementCarts)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(abonnement.ClubLogo))
                                {
                                    <img src="@abonnement.ClubLogo" height="30" class="me-2" />
                                }
                                @abonnement.ClubNaam
                            </td>
                            <td>€@abonnement.Prijs</td>
                            <td>
                                <a asp-action="DeleteAbonnement"
                                   asp-route-clubId="@abonnement.ClubId"
                                   class="btn btn-danger btn-sm">Verwijder</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }


@if (Model?.Carts?.Any() != true && Model?.AbonnementCarts?.Any() != true)
{
    <p>Je winkelmandje is leeg.</p>
}
else
{
    <form asp-action="CreateTicket" method="post">
        <div class="row mt-3">
            <div class="col-md-6">
                <input type="submit" value="Bevestig bestelling" class="btn btn-primary" />
            </div>
            <div class="col-md-6 text-end">
                <strong>Totaal: €@Model!.ComputeTotalValue()</strong>
            </div>
        </div>
    </form>
}

<a asp-controller="Match" asp-action="Index" class="btn btn-secondary mt-3">
    Verder winkelen
</a>